# ========================================
# 售后数据管理系统 - 生产环境配置
# ========================================
# 部署步骤：
# 1. cp .env.example .env
# 2. 填写下方所有必填项
# 3. npm install && node server.js
# ========================================

# 运行环境 (production / development)
NODE_ENV=production

# 服务器端口
PORT=3000

# PostgreSQL 数据库连接串（Supabase / Render PostgreSQL）
# 格式：postgresql://user:password@host:6543/dbname
# 不设置则使用本地 localStorage 模式
# Supabase: 在 Supabase Dashboard > Project Settings > Database 中复制
#   - 选择 "Connection string" 标签
#   - 使用 "Transaction" 模式（端口 6543）
#   - 替换 [YOUR-PASSWORD] 为你的数据库密码
# DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# 应用访问地址（必须与飞书开放平台配置的安全域名一致）
# 本地开发：http://localhost:3000
# 生产部署：https://your-domain.com
BASE_URL=https://your-domain.com

# ============================================
# 飞书自建应用配置
# ============================================

# 是否启用飞书集成
FEISHU_ENABLED=true

# 飞书应用凭证（在飞书开发者后台 > 凭证与基础信息 中获取）
FEISHU_APP_ID=cli_aXXXXXXXXXXX
FEISHU_APP_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# 飞书企业组织 ID（在飞书管理后台 > 组织架构 中查找）
# 留空则跳过组织校验
FEISHU_ORG_ID=

# 应用名称（会显示在飞书工作台）
FEISHU_APP_NAME=售后数据管理系统

# ============================================
# 飞书开放平台配置指南（部署后需更新）
# ============================================
#
# 以下配置需在 https://open.feishu.cn/app 中修改：
#
# 1. 网页应用主页 URL
#    将 {BASE_URL} 替换为实际域名：
#    - 桌面端主页：{BASE_URL}
#    - 移动端主页：{BASE_URL}
#
# 2. OAuth 重定向 URL
#    安全设置 → 重定向 URL：
#    {BASE_URL}/api/auth/feishu/callback
#
# 3. H5 可信域名
#    安全设置 → H5 可信域名：
#    your-domain.com（不含协议前缀）
#
# 4. 权限配置
#    在「权限管理」中搜索并开通：
#    - contact:user.base:readonly   （获取用户基本信息）
#    - im:message:send_as_bot       （以机器人身份发送消息）
#    - im:message                   （获取与发送消息）
#    - contact:contact:readonly     （通讯录访问，搜索用户功能需要）
#
# 5. 发布应用
#    配置完成后，创建应用版本并发布
#    管理员审核通过后即可使用
# ============================================
